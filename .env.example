# MyAgent Configuration Example
# Copy this to .env and fill in your actual values

# ============================================
# LLM Configuration
# ============================================
# ⚠️  必须配置以下三项才能工作:
# 1. LLM_MODEL - 模型名称
# 2. LLM_API_KEY - API密钥（从你的服务商获取）
# 3. LLM_BASE_URL - API地址

# 🔸 方案1: 阿里通义千问 (Qwen)
LLM_MODEL=qwen-plus
LLM_API_KEY=your-aliyun-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 🔸 方案2: OpenAI (GPT-4) - 取消注释后改成这个
# LLM_MODEL=gpt-4
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1

# 🔸 方案3: DeepSeek - 取消注释后改成这个
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1

# 🔸 方案4: 本地 Ollama
# LLM_MODEL=llama2
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================
# Embedding Configuration
# ============================================
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=auto  # 自动检测

# ============================================
# Vector Database Configuration
# ============================================
# SQLite模式 (默认, 无需额外配置)
USE_MILVUS=false

# 或 Milvus模式 (需要Milvus服务运行)
# USE_MILVUS=true
# MILVUS_URI=http://localhost:19530
# MILVUS_DB_NAME=myagent
# MILVUS_COLLECTION_NAME=chunks

# ============================================
# Application Settings
# ============================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# Optional: Weather Provider
AMAP_API_KEY=your-amap-key

# ============================================
# Optional: Alternative LLM Providers
# ============================================

# Azure OpenAI
# LLM_MODEL=gpt-4-deployment-name
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments
# LLM_API_KEY=your-azure-key

# 本地 Ollama
# LLM_MODEL=llama2
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# 阿里通义千问
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-...

# 百度文心一言
# LLM_MODEL=ernie-bot-turbo
# LLM_BASE_URL=https://api.baidu.com/v1
# LLM_API_KEY=your-api-key

# ============================================
# Optional: Docker Compose Overrides
# ============================================
# 如果使用docker-compose.override.yml，
# 可以在那里设置敏感信息而不提交到版本控制


# ============================================
# 天气 API配置 (可选, 仅天气穿搭Agent需要) ,高德
AMAP_API_KEY=your-amap-key